<div class="space-y-6">
  <%# Welcome Header %>
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Hello, <%= current_user.first_name %>!</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Here's what your agent is up to</p>
    </div>
    <% if current_user.photo.attached? %>
      <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-indigo-200 dark:border-indigo-700">
        <%= image_tag current_user.photo, class: "w-full h-full object-cover" %>
      </div>
    <% end %>
  </div>

  <%# Agent Status Card %>
  <div class="bg-gradient-to-r from-indigo-600 to-purple-600 rounded-2xl p-6 text-white shadow-lg">
    <div class="flex items-start justify-between">
      <div>
        <div class="flex items-center gap-2">
          <div class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></div>
          <span class="text-sm font-medium text-indigo-100">Agent Active</span>
        </div>
        <h2 class="text-xl font-bold mt-2"><%= @agent&.name || "No Agent Set Up" %></h2>
        <p class="text-sm text-indigo-200 mt-1">
          <% if @agent %>
            <%= @agent.personality_mode&.titleize || "Friendly" %> mode &middot;
            <%= @agent.aggressiveness_level.titleize %> pace
            (<%= @agent.match_cap_per_week %> matches/week)
          <% else %>
            Set up your agent to get started
          <% end %>
        </p>
      </div>
      <%= link_to agent_path, class: "bg-white/20 hover:bg-white/30 rounded-lg px-4 py-2 text-sm font-medium transition-colors" do %>
        Configure
      <% end %>
    </div>
  </div>

  <%# Stats Row %>
  <div class="grid grid-cols-3 gap-3">
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-4 text-center">
      <p class="text-2xl font-bold text-indigo-600 dark:text-indigo-400"><%= @matches.count %></p>
      <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Active Matches</p>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-4 text-center">
      <p class="text-2xl font-bold text-pink-600 dark:text-pink-400"><%= @upcoming_dates.count %></p>
      <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Upcoming Dates</p>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-4 text-center">
      <p class="text-2xl font-bold text-green-600 dark:text-green-400"><%= @recent_confirmed.count %></p>
      <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Confirmed</p>
    </div>
  </div>

  <%# Upcoming Dates %>
  <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700">
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Upcoming Dates</h2>
    </div>
    <div class="divide-y divide-gray-200 dark:divide-gray-700">
      <% if @upcoming_dates.any? %>
        <% @upcoming_dates.each do |date_event| %>
          <% other_user = match_other_user(date_event.match) %>
          <% is_past = date_event.scheduled_time && date_event.scheduled_time < Time.current %>
          <div class="px-6 py-4 hover:bg-gray-50 dark:hover:bg-gray-750 transition-colors">
            <%= link_to match_path(date_event.match), class: "block" do %>
              <div class="flex items-center gap-3">
                <%# Photo %>
                <div class="flex-shrink-0">
                  <% if other_user.photo.attached? && other_user.photo.blob&.persisted? %>
                    <div class="w-11 h-11 rounded-full overflow-hidden shadow-sm">
                      <%= image_tag other_user.photo, class: "w-full h-full object-cover" %>
                    </div>
                  <% else %>
                    <div class="w-11 h-11 rounded-full bg-gradient-to-br from-indigo-400 to-pink-400 flex items-center justify-center shadow-sm">
                      <span class="text-sm font-bold text-white"><%= other_user.first_name[0] %></span>
                    </div>
                  <% end %>
                </div>

                <%# Details %>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center justify-between gap-2">
                    <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 truncate">Date with <%= other_user.first_name %></h3>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-medium flex-shrink-0 <%= booking_status_badge(date_event.booking_status) %>">
                      <%= date_event.booking_status&.titleize || "Pending" %>
                    </span>
                  </div>

                  <%# Venue info %>
                  <% if date_event.venue %>
                    <div class="flex items-center gap-1.5 mt-0.5">
                      <svg class="w-3.5 h-3.5 text-gray-400 dark:text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                      <p class="text-xs text-gray-600 dark:text-gray-300 truncate"><%= date_event.venue.name %></p>
                      <% if date_event.venue.venue_type.present? %>
                        <span class="text-[11px] text-gray-400 dark:text-gray-500">· <%= date_event.venue.venue_type.titleize %></span>
                      <% end %>
                    </div>
                  <% else %>
                    <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">Venue TBD</p>
                  <% end %>

                  <%# Date & time %>
                  <% if date_event.scheduled_time %>
                    <div class="flex items-center gap-1.5 mt-0.5">
                      <svg class="w-3.5 h-3.5 text-gray-400 dark:text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                      <p class="text-xs text-gray-500 dark:text-gray-400"><%= date_event.scheduled_time.strftime("%a, %b %d") %> at <%= date_event.scheduled_time.strftime("%I:%M %p") %></p>
                      <% if is_past %>
                        <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-gray-100 text-gray-500 dark:bg-gray-700 dark:text-gray-400">Past</span>
                      <% end %>
                    </div>
                  <% else %>
                    <div class="flex items-center gap-1.5 mt-0.5">
                      <svg class="w-3.5 h-3.5 text-gray-400 dark:text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                      <p class="text-xs text-gray-400 dark:text-gray-500">Date TBD</p>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>

            <%# Accept / Decline actions — outside the link, full-width row %>
            <% if date_event.booking_status == "proposed" %>
              <div class="flex items-center gap-2 mt-3 ml-14">
                <%= link_to accept_date_event_path(date_event), method: :patch, data: { turbo_method: :patch }, class: "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium bg-green-100 text-green-700 hover:bg-green-200 dark:bg-green-900/30 dark:text-green-400 dark:hover:bg-green-900/50 transition-colors" do %>
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  Accept
                <% end %>
                <%= link_to decline_date_event_path(date_event), method: :patch, data: { turbo_method: :patch }, class: "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium bg-red-100 text-red-700 hover:bg-red-200 dark:bg-red-900/30 dark:text-red-400 dark:hover:bg-red-900/50 transition-colors" do %>
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                  Decline
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div class="px-6 py-12 text-center">
          <svg class="w-12 h-12 text-gray-300 dark:text-gray-600 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          <p class="text-sm text-gray-500 dark:text-gray-400">No upcoming dates yet</p>
          <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Your agent is working on finding matches!</p>
        </div>
      <% end %>
    </div>
  </div>

  <%# Recent Matches — Tabbed Card View %>
  <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700"
       data-controller="match-tabs" data-match-tabs-active-value="proposed">

    <%# Header with View All %>
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Recent Matches</h2>
      <%= link_to "View All", matches_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-500 dark:text-indigo-400" %>
    </div>

    <%# Tab Navigation — pill style matching /matches %>
    <div class="flex gap-2 overflow-x-auto px-6 py-4 -mx-0">
      <button data-match-tabs-target="tab" data-tab="proposed" data-action="click->match-tabs#switch"
              class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium whitespace-nowrap transition-colors bg-indigo-600 text-white">
        Date Proposed
      </button>
      <button data-match-tabs-target="tab" data-tab="confirmed" data-action="click->match-tabs#switch"
              class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium whitespace-nowrap transition-colors bg-white dark:bg-gray-700 text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-600">
        Confirmed
      </button>
      <button data-match-tabs-target="tab" data-tab="declined" data-action="click->match-tabs#switch"
              class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium whitespace-nowrap transition-colors bg-white dark:bg-gray-700 text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-600">
        Declined
      </button>
    </div>

    <%# === Proposed Panel === %>
    <div data-match-tabs-target="panel" data-tab="proposed" class="pb-6 pt-2">
      <% if @proposed_matches.any? %>
        <%# Arrow + Card row %>
        <div class="flex items-center gap-0.5 sm:gap-1 px-1 sm:px-2">
          <button data-action="click->match-tabs#prev" class="flex-shrink-0 w-6 h-6 sm:w-8 sm:h-8 flex items-center justify-center rounded-full text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
            <svg class="w-3.5 h-3.5 sm:w-5 sm:h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <div class="flex-1 min-w-0">
            <% @proposed_matches.each_with_index do |match, i| %>
              <% other_user = match_other_user(match) %>
              <%= link_to match_path(match), class: "block bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-4 sm:p-5 hover:shadow-md transition-shadow #{i == 0 ? '' : 'hidden'}", data: { match_tabs_target: "card" } do %>
                <div class="flex items-start gap-4">
                  <% if other_user.photo.attached? && other_user.photo.blob&.persisted? %>
                    <div class="w-14 h-14 rounded-xl overflow-hidden flex-shrink-0 shadow-sm">
                      <%= image_tag other_user.photo, class: "w-full h-full object-cover" %>
                    </div>
                  <% else %>
                    <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-indigo-400 to-pink-400 flex items-center justify-center flex-shrink-0 shadow-sm">
                      <span class="text-lg font-bold text-white"><%= other_user.first_name[0] %></span>
                    </div>
                  <% end %>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between gap-2">
                      <h3 class="text-base font-semibold text-gray-900 dark:text-gray-100 truncate"><%= other_user.first_name %></h3>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium flex-shrink-0 <%= status_badge_classes(match.status) %>">
                        <%= match.status&.titleize %>
                      </span>
                    </div>
                    <% if other_user.city.present? %>
                      <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5"><%= other_user.city %><%= ", #{other_user.country}" if other_user.country.present? %></p>
                    <% end %>
                    <% if match.compatibility_score %>
                      <div class="mt-3">
                        <div class="flex items-center justify-between mb-1">
                          <span class="text-xs font-medium text-gray-500 dark:text-gray-400">Compatibility</span>
                          <span class="text-xs font-bold text-indigo-600 dark:text-indigo-400"><%= match.compatibility_score.round %>%</span>
                        </div>
                        <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-1.5">
                          <div class="bg-gradient-to-r from-indigo-500 to-pink-500 h-1.5 rounded-full" style="width: <%= match.compatibility_score.round %>%"></div>
                        </div>
                      </div>
                    <% end %>
                    <% if match.compatibility_summary.present? %>
                      <p class="text-xs text-gray-500 dark:text-gray-400 mt-2 line-clamp-2"><%= match.compatibility_summary %></p>
                    <% end %>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
          <button data-action="click->match-tabs#next" class="flex-shrink-0 w-6 h-6 sm:w-8 sm:h-8 flex items-center justify-center rounded-full text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
            <svg class="w-3.5 h-3.5 sm:w-5 sm:h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>

        <%# Pagination dots %>
        <div class="flex justify-center gap-4 mt-4">
          <% @proposed_matches.each_with_index do |_, i| %>
            <span data-match-tabs-target="dot" data-index="<%= i %>" data-action="click->match-tabs#goToCard"
                  style="width: 12px; height: 12px; display: inline-block; border-radius: 9999px; cursor: pointer; background-color: <%= i == 0 ? '#9333ea' : '#e9d5ff' %>;"></span>
          <% end %>
        </div>
      <% else %>
        <div class="py-10 text-center">
          <svg class="w-12 h-12 text-gray-300 dark:text-gray-600 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          <p class="text-sm text-gray-500 dark:text-gray-400">No proposed dates yet</p>
          <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Your agent is working on finding matches!</p>
        </div>
      <% end %>
    </div>

    <%# === Confirmed Panel === %>
    <div data-match-tabs-target="panel" data-tab="confirmed" class="pb-6 pt-2 hidden">
      <% if @confirmed_matches.any? %>
        <div class="flex items-center gap-0.5 sm:gap-1 px-1 sm:px-2">
          <button data-action="click->match-tabs#prev" class="flex-shrink-0 w-6 h-6 sm:w-8 sm:h-8 flex items-center justify-center rounded-full text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
            <svg class="w-3.5 h-3.5 sm:w-5 sm:h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <div class="flex-1 min-w-0">
            <% @confirmed_matches.each_with_index do |match, i| %>
              <% other_user = match_other_user(match) %>
              <%= link_to match_path(match), class: "block bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-4 sm:p-5 hover:shadow-md transition-shadow #{i == 0 ? '' : 'hidden'}", data: { match_tabs_target: "card" } do %>
                <div class="flex items-start gap-4">
                  <% if other_user.photo.attached? && other_user.photo.blob&.persisted? %>
                    <div class="w-14 h-14 rounded-xl overflow-hidden flex-shrink-0 shadow-sm">
                      <%= image_tag other_user.photo, class: "w-full h-full object-cover" %>
                    </div>
                  <% else %>
                    <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-indigo-400 to-pink-400 flex items-center justify-center flex-shrink-0 shadow-sm">
                      <span class="text-lg font-bold text-white"><%= other_user.first_name[0] %></span>
                    </div>
                  <% end %>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between gap-2">
                      <h3 class="text-base font-semibold text-gray-900 dark:text-gray-100 truncate"><%= other_user.first_name %></h3>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium flex-shrink-0 <%= status_badge_classes(match.status) %>">
                        <%= match.status&.titleize %>
                      </span>
                    </div>
                    <% if other_user.city.present? %>
                      <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5"><%= other_user.city %><%= ", #{other_user.country}" if other_user.country.present? %></p>
                    <% end %>
                    <% if match.compatibility_score %>
                      <div class="mt-3">
                        <div class="flex items-center justify-between mb-1">
                          <span class="text-xs font-medium text-gray-500 dark:text-gray-400">Compatibility</span>
                          <span class="text-xs font-bold text-indigo-600 dark:text-indigo-400"><%= match.compatibility_score.round %>%</span>
                        </div>
                        <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-1.5">
                          <div class="bg-gradient-to-r from-indigo-500 to-pink-500 h-1.5 rounded-full" style="width: <%= match.compatibility_score.round %>%"></div>
                        </div>
                      </div>
                    <% end %>
                    <% if match.compatibility_summary.present? %>
                      <p class="text-xs text-gray-500 dark:text-gray-400 mt-2 line-clamp-2"><%= match.compatibility_summary %></p>
                    <% end %>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
          <button data-action="click->match-tabs#next" class="flex-shrink-0 w-6 h-6 sm:w-8 sm:h-8 flex items-center justify-center rounded-full text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
            <svg class="w-3.5 h-3.5 sm:w-5 sm:h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>

        <div class="flex justify-center gap-4 mt-4">
          <% @confirmed_matches.each_with_index do |_, i| %>
            <span data-match-tabs-target="dot" data-index="<%= i %>" data-action="click->match-tabs#goToCard"
                  style="width: 12px; height: 12px; display: inline-block; border-radius: 9999px; cursor: pointer; background-color: <%= i == 0 ? '#9333ea' : '#e9d5ff' %>;"></span>
          <% end %>
        </div>
      <% else %>
        <div class="py-10 text-center">
          <svg class="w-12 h-12 text-gray-300 dark:text-gray-600 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          <p class="text-sm text-gray-500 dark:text-gray-400">No confirmed matches yet</p>
          <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Confirmed dates will appear here</p>
        </div>
      <% end %>
    </div>

    <%# === Declined Panel === %>
    <div data-match-tabs-target="panel" data-tab="declined" class="pb-6 pt-2 hidden">
      <% if @declined_matches.any? %>
        <div class="flex items-center gap-0.5 sm:gap-1 px-1 sm:px-2">
          <button data-action="click->match-tabs#prev" class="flex-shrink-0 w-6 h-6 sm:w-8 sm:h-8 flex items-center justify-center rounded-full text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
            <svg class="w-3.5 h-3.5 sm:w-5 sm:h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <div class="flex-1 min-w-0">
            <% @declined_matches.each_with_index do |match, i| %>
              <% other_user = match_other_user(match) %>
              <%= link_to match_path(match), class: "block bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-4 sm:p-5 hover:shadow-md transition-shadow #{i == 0 ? '' : 'hidden'}", data: { match_tabs_target: "card" } do %>
                <div class="flex items-start gap-4">
                  <% if other_user.photo.attached? && other_user.photo.blob&.persisted? %>
                    <div class="w-14 h-14 rounded-xl overflow-hidden flex-shrink-0 shadow-sm">
                      <%= image_tag other_user.photo, class: "w-full h-full object-cover" %>
                    </div>
                  <% else %>
                    <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-indigo-400 to-pink-400 flex items-center justify-center flex-shrink-0 shadow-sm">
                      <span class="text-lg font-bold text-white"><%= other_user.first_name[0] %></span>
                    </div>
                  <% end %>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between gap-2">
                      <h3 class="text-base font-semibold text-gray-900 dark:text-gray-100 truncate"><%= other_user.first_name %></h3>
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium flex-shrink-0 <%= status_badge_classes(match.status) %>">
                        <%= match.status&.titleize %>
                      </span>
                    </div>
                    <% if other_user.city.present? %>
                      <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5"><%= other_user.city %><%= ", #{other_user.country}" if other_user.country.present? %></p>
                    <% end %>
                    <% if match.compatibility_score %>
                      <div class="mt-3">
                        <div class="flex items-center justify-between mb-1">
                          <span class="text-xs font-medium text-gray-500 dark:text-gray-400">Compatibility</span>
                          <span class="text-xs font-bold text-indigo-600 dark:text-indigo-400"><%= match.compatibility_score.round %>%</span>
                        </div>
                        <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-1.5">
                          <div class="bg-gradient-to-r from-indigo-500 to-pink-500 h-1.5 rounded-full" style="width: <%= match.compatibility_score.round %>%"></div>
                        </div>
                      </div>
                    <% end %>
                    <% if match.compatibility_summary.present? %>
                      <p class="text-xs text-gray-500 dark:text-gray-400 mt-2 line-clamp-2"><%= match.compatibility_summary %></p>
                    <% end %>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
          <button data-action="click->match-tabs#next" class="flex-shrink-0 w-6 h-6 sm:w-8 sm:h-8 flex items-center justify-center rounded-full text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
            <svg class="w-3.5 h-3.5 sm:w-5 sm:h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>

        <div class="flex justify-center gap-4 mt-4">
          <% @declined_matches.each_with_index do |_, i| %>
            <span data-match-tabs-target="dot" data-index="<%= i %>" data-action="click->match-tabs#goToCard"
                  style="width: 12px; height: 12px; display: inline-block; border-radius: 9999px; cursor: pointer; background-color: <%= i == 0 ? '#9333ea' : '#e9d5ff' %>;"></span>
          <% end %>
        </div>
      <% else %>
        <div class="py-10 text-center">
          <svg class="w-12 h-12 text-gray-300 dark:text-gray-600 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          <p class="text-sm text-gray-500 dark:text-gray-400">No declined matches</p>
          <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Declined matches will appear here</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
