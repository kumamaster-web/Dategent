<% other_user = match_other_user(@match) %>

<div class="max-w-2xl mx-auto space-y-6">
  <%# Back Link %>
  <div>
    <%= link_to matches_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Back to Matches
    <% end %>
  </div>

  <%# Match Header Card %>
  <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
    <div class="h-24 bg-gradient-to-r from-indigo-500 to-pink-500"></div>
    <div class="px-6 pb-6">
      <div class="-mt-10 flex items-end gap-4">
        <% if other_user.photo.attached? && other_user.photo.blob&.persisted? %>
          <div class="w-20 h-20 rounded-xl border-4 border-white dark:border-gray-800 overflow-hidden shadow-lg flex-shrink-0">
            <%= image_tag other_user.photo, class: "w-full h-full object-cover" %>
          </div>
        <% else %>
          <div class="w-20 h-20 rounded-xl border-4 border-white dark:border-gray-800 bg-gradient-to-br from-indigo-400 to-pink-400 flex items-center justify-center shadow-lg flex-shrink-0">
            <span class="text-2xl font-bold text-white"><%= other_user.first_name[0] %></span>
          </div>
        <% end %>
        <div class="pb-1">
          <h1 class="text-xl font-bold text-gray-900 dark:text-gray-100"><%= other_user.first_name %></h1>
          <p class="text-sm text-gray-500 dark:text-gray-400">
            <% if other_user.city.present? %>
              <%= other_user.city %><%= ", #{other_user.country}" if other_user.country.present? %>
            <% end %>
            <% if other_user.age %>
              &middot; <%= other_user.age %> years old
            <% end %>
          </p>
        </div>
      </div>

      <%# Status & Score %>
      <div class="mt-4 flex items-center gap-3">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium <%= status_badge_classes(@match.status) %>">
          <%= @match.status&.titleize %>
        </span>
        <% if @match.compatibility_score %>
          <span class="text-sm font-medium text-gray-600 dark:text-gray-400">
            <span class="text-indigo-600 dark:text-indigo-400 font-bold"><%= @match.compatibility_score.round %>%</span> compatible
          </span>
        <% end %>
      </div>

      <%# Compatibility Score Bar %>
      <% if @match.compatibility_score %>
        <div class="mt-4">
          <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2">
            <div class="bg-gradient-to-r from-indigo-500 to-pink-500 h-2 rounded-full transition-all" style="width: <%= @match.compatibility_score.round %>%"></div>
          </div>
        </div>
      <% end %>

      <%# Compatibility Breakdown %>
      <%= render "matches/compatibility_breakdown" %>
    </div>
  </div>

  <%# Date Events %>
  <% if @date_events.any? %>
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700">
      <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Date Proposals</h2>
      </div>
      <div class="divide-y divide-gray-200 dark:divide-gray-700">
        <% @date_events.each do |date_event| %>
          <div class="px-6 py-4">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-amber-100 dark:bg-amber-900/30 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= date_event.venue&.name || "Venue TBD" %></p>
                  <p class="text-xs text-gray-500 dark:text-gray-400">
                    <% if date_event.scheduled_time %>
                      <%= date_event.scheduled_time.strftime("%A, %B %d at %I:%M %p") %>
                    <% else %>
                      Time TBD
                    <% end %>
                    <% if date_event.venue&.address %>
                      &middot; <%= date_event.venue.address %>
                    <% end %>
                  </p>
                </div>
              </div>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= booking_status_badge(date_event.booking_status) %>">
                <%= date_event.booking_status&.titleize %>
              </span>
            </div>

            <% if date_event.booking_status == "proposed" %>
              <div class="mt-3 flex gap-2">
                <%= link_to accept_date_event_path(date_event), method: :patch, data: { turbo_method: :patch }, class: "inline-flex items-center gap-1.5 bg-green-600 hover:bg-green-700 text-white text-sm font-medium py-2 px-4 rounded-lg transition-colors" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  Accept Date
                <% end %>
                <%= link_to decline_date_event_path(date_event), method: :patch, data: { turbo_method: :patch }, class: "inline-flex items-center gap-1.5 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 text-red-600 dark:text-red-400 text-sm font-medium py-2 px-4 rounded-lg border border-gray-300 dark:border-gray-600 transition-colors" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                  Decline
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Agent-to-Agent Transcript Timeline %>
  <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 flex items-center gap-2">
        <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
        Agent Conversation History
      </h2>
      <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
        Full timeline of what your agents discussed at each stage
        <% if @transcripts.any? %>
          &middot; <%= @transcripts.size %> stage<%= @transcripts.size == 1 ? '' : 's' %>
        <% end %>
      </p>
    </div>
    <div class="p-6">
      <% if @transcripts.any? %>
        <%# Timeline with collapsible stage sections %>
        <div class="relative" data-controller="transcript-accordion">
          <%# Vertical timeline line %>
          <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-gray-200 dark:bg-gray-700"></div>

          <div class="space-y-6">
            <% @transcripts.each_with_index do |transcript, idx| %>
              <% is_last = idx == @transcripts.size - 1 %>
              <% stage_colors = {
                "screening" => { bg: "bg-blue-100 dark:bg-blue-900/30", text: "text-blue-600 dark:text-blue-400", ring: "ring-blue-500" },
                "evaluating" => { bg: "bg-amber-100 dark:bg-amber-900/30", text: "text-amber-600 dark:text-amber-400", ring: "ring-amber-500" },
                "date_proposed" => { bg: "bg-purple-100 dark:bg-purple-900/30", text: "text-purple-600 dark:text-purple-400", ring: "ring-purple-500" },
                "confirmed" => { bg: "bg-green-100 dark:bg-green-900/30", text: "text-green-600 dark:text-green-400", ring: "ring-green-500" },
                "declined" => { bg: "bg-red-100 dark:bg-red-900/30", text: "text-red-600 dark:text-red-400", ring: "ring-red-500" }
              } %>
              <% colors = stage_colors[transcript.stage] || stage_colors["screening"] %>

              <div class="relative pl-12">
                <%# Timeline dot %>
                <div class="absolute left-2 w-5 h-5 rounded-full <%= colors[:bg] %> ring-2 ring-white dark:ring-gray-800 flex items-center justify-center z-10 <%= is_last ? 'ring-2 ' + colors[:ring] : '' %>">
                  <% if transcript.stage == "screening" %>
                    <svg class="w-2.5 h-2.5 <%= colors[:text] %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                  <% elsif transcript.stage == "evaluating" %>
                    <svg class="w-2.5 h-2.5 <%= colors[:text] %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                  <% elsif transcript.stage == "date_proposed" %>
                    <svg class="w-2.5 h-2.5 <%= colors[:text] %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  <% elsif transcript.stage == "confirmed" %>
                    <svg class="w-2.5 h-2.5 <%= colors[:text] %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                  <% elsif transcript.stage == "declined" %>
                    <svg class="w-2.5 h-2.5 <%= colors[:text] %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"/></svg>
                  <% end %>
                </div>

                <%# Stage card %>
                <div class="border border-gray-200 dark:border-gray-700 rounded-xl overflow-hidden">
                  <%# Collapsible header %>
                  <button
                    type="button"
                    class="w-full px-4 py-3 flex items-center justify-between text-left hover:bg-gray-50 dark:hover:bg-gray-750 transition-colors"
                    data-action="click->transcript-accordion#toggle"
                    data-transcript-accordion-target="button"
                    data-index="<%= idx %>"
                  >
                    <div class="flex items-center gap-3">
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold <%= colors[:bg] %> <%= colors[:text] %>">
                        <%= transcript.stage_label %>
                      </span>
                      <span class="text-xs text-gray-400 dark:text-gray-500">
                        <%= transcript.created_at.strftime("%b %d, %Y at %I:%M %p") %>
                      </span>
                    </div>
                    <svg
                      class="w-4 h-4 text-gray-400 dark:text-gray-500 transform transition-transform duration-200"
                      data-transcript-accordion-target="chevron"
                      fill="none" stroke="currentColor" viewBox="0 0 24 24"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </button>

                  <%# Collapsible content — chat bubble layout %>
                  <div
                    data-transcript-accordion-target="panel"
                    class="<%= is_last ? '' : 'hidden' %>"
                  >
                    <div class="border-t border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/40">
                      <%# Agent identity %>
                      <% my_agent = current_user.agent %>
                      <% their_agent = (my_agent == @match.initiator_agent) ? @match.receiver_agent : @match.initiator_agent %>

                      <div class="px-4 py-4 space-y-3 max-h-96 overflow-y-auto">
                        <%# Pre-process: group multi-line messages by speaker %>
                        <% speaker_regex = /\A\s*\[(.+?)(?:\s*→\s*(.+?))?\]:?\s*(.*)\z/ %>
                        <% grouped_messages = [] %>
                        <% transcript.content.split("\n").each do |line| %>
                          <% if line.match?(speaker_regex) %>
                            <% md = line.match(speaker_regex) %>
                            <% grouped_messages << { speaker: md[1].strip, lines: [md[3].strip].reject(&:blank?) } %>
                          <% elsif line.strip.present? && grouped_messages.any? && grouped_messages.last[:speaker].present? %>
                            <% grouped_messages.last[:lines] << line.strip %>
                          <% elsif line.strip.present? %>
                            <% grouped_messages << { speaker: nil, lines: [line.strip] } %>
                          <% end %>
                        <% end %>

                        <% grouped_messages.each do |msg| %>
                          <% if msg[:speaker].present? %>
                            <% is_mine = my_agent&.name && msg[:speaker].include?(my_agent.name.split("'s").first) %>
                            <% if is_mine %>
                              <%# Current user's agent — right-aligned indigo bubble %>
                              <div class="flex justify-end">
                                <div class="max-w-[85%] sm:max-w-[75%]">
                                  <p class="text-[11px] font-bold text-indigo-400 dark:text-indigo-300 mb-0.5 text-right"><%= my_agent&.name || "Your Agent" %></p>
                                  <div class="rounded-2xl rounded-br-md px-4 py-2.5 bg-indigo-500 dark:bg-indigo-600 shadow-sm">
                                    <% msg[:lines].each_with_index do |para, i| %>
                                      <p class="text-sm text-white leading-relaxed <%= 'mt-2' if i > 0 %>"><%= para %></p>
                                    <% end %>
                                  </div>
                                </div>
                              </div>
                            <% else %>
                              <%# Other user's agent — left-aligned pink bubble %>
                              <div class="flex justify-start">
                                <div class="max-w-[85%] sm:max-w-[75%]">
                                  <p class="text-[11px] font-bold text-pink-400 dark:text-pink-300 mb-0.5"><%= their_agent&.name || "Their Agent" %></p>
                                  <div class="rounded-2xl rounded-bl-md px-4 py-2.5 bg-pink-500 dark:bg-pink-600 shadow-sm">
                                    <% msg[:lines].each_with_index do |para, i| %>
                                      <p class="text-sm text-white leading-relaxed <%= 'mt-2' if i > 0 %>"><%= para %></p>
                                    <% end %>
                                  </div>
                                </div>
                              </div>
                            <% end %>
                          <% else %>
                            <%# System/non-dialogue line — centered muted text %>
                            <% msg[:lines].each do |sys_line| %>
                              <div class="flex justify-center">
                                <p class="text-xs text-gray-400 dark:text-gray-500 italic px-3 py-1"><%= sys_line %></p>
                              </div>
                            <% end %>
                          <% end %>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% elsif @match.chat_transcript.present? %>
        <%# Fallback: show legacy chat_transcript if no match_transcripts exist yet %>
        <div class="bg-gray-50 dark:bg-gray-900/40 rounded-xl p-4 space-y-3 max-h-96 overflow-y-auto">
          <% begin %>
            <% messages = JSON.parse(@match.chat_transcript) %>
            <% messages.each do |msg| %>
              <% is_mine = msg['role'] == 'initiator' && @match.initiator_agent.user == current_user ||
                           msg['role'] != 'initiator' && @match.initiator_agent.user != current_user %>
              <div class="flex <%= is_mine ? 'justify-end' : 'justify-start' %>">
                <div class="max-w-[85%] sm:max-w-[75%]">
                  <div class="rounded-2xl px-4 py-2.5 shadow-sm <%= is_mine ? 'rounded-br-md bg-indigo-500 dark:bg-indigo-600' : 'rounded-bl-md bg-pink-500 dark:bg-pink-600' %>">
                    <p class="text-sm text-white leading-relaxed"><%= msg['content'] %></p>
                  </div>
                </div>
              </div>
            <% end %>
          <% rescue JSON::ParserError %>
            <div class="prose prose-sm dark:prose-invert max-w-none">
              <p class="text-sm text-gray-700 dark:text-gray-300 whitespace-pre-wrap"><%= @match.chat_transcript %></p>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-8">
          <svg class="w-12 h-12 text-gray-300 dark:text-gray-600 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          <p class="text-sm text-gray-500 dark:text-gray-400">No conversation yet</p>
          <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Your agents haven't started talking yet</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
